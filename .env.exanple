# Frontend Mappings (Must be prefixed for Next.js client-side access)
NEXT_PUBLIC_DEFAULT_PROVIDER=gemini
NEXT_PUBLIC_DEFAULT_MODEL=gemini-2.0-flash

# API Keys
GOOGLE_API_KEY=your_ai_studio_key
GITHUB_TOKEN=your_github_copilot_token

#github_oAuth
GITHUB_CLIENTID=
GITHUB_SECRET=
AUTH_SECRET=
PROVIDER_DEBUG=false

# MCP Server Settings
PORT=41234
DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=5000
