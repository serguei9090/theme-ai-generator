PORT=41234
DEBUG=false
DEFAULT_PROVIDER=ollama

# === CORS ===
# Comma-separated allowed origins for browser access.
# Do NOT use wildcard (*) in production.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# === Ollama (local LLM) ===
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=mistral:latest
OLLAMA_TIMEOUT=20000

# === OpenAI ===
OPENAI_API_KEY=
OPENAI_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=8000

# === AIStudio (Google's AI Studio / Gemini API) ===
AISTUDIO_API_KEY=
AISTUDIO_API_URL=
AISTUDIO_DEFAULT_MODEL=

# === GitHub Copilot SDK ===
# Requires GitHub Copilot CLI available on PATH
COPILOT_MODEL=gpt-5
COPILOT_TIMEOUT=20000
# Optional when using non-interactive auth:
GITHUB_TOKEN=
