{
  "name": "theme-ai-generator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && bun run dev",
    "mcp": "bun run packages/mcp-server/src/server.ts",
    "mcp:dev": "bun --watch packages/mcp-server/src/server.ts",
    "build:mcp": "bun build packages/mcp-server/src/server.ts --outfile packages/mcp-server/dist/index.js --bundle --target bun",
    "compile:mcp": "bun build packages/mcp-server/src/server.ts --compile --outfile mcp-server",
    "build": "bun run build:web",
    "build:web": "cd apps/web && bun run build",
    "start": "bun run start:web",
    "start:web": "cd apps/web && bun run start",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "bun run typecheck:web",
    "typecheck:web": "bunx tsc --project apps/web/tsconfig.json --noEmit",
    "test": "bun test apps/web/src/lib/*.test.ts packages/core/src/*.test.ts packages/mcp-server/src/*.test.ts",
    "test:web": "cd apps/web && bun run test",
    "test:core": "bun test packages/core/src/*.test.ts",
    "test:mcp": "bun test packages/mcp-server/src/*.test.ts",
    "test:manual-mcp": "bun run scripts/mcp-test.ts",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lefthook": "^1.12.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
