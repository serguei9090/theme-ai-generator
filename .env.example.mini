# Minimal Fast Setup for Ollama (Local)
# Use this for testing without cloud API keys

# Frontend Mappings
NEXT_PUBLIC_DEFAULT_PROVIDER=ollama
NEXT_PUBLIC_DEFAULT_MODEL=llama3.1:8b

# Provider Settings
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=30000

# Auth (Dummy values for local testing)
AUTH_SECRET=fast_setup_only_do_not_use_in_production
PROVIDER_DEBUG=true

# NextAuth (Optional, only if using GitHub Login)
# GITHUB_CLIENTID=
# GITHUB_SECRET=
