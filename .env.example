# === Theme AI Generator Configuration ===

# 🎨 Default Generation Settings
# Options: gemini, ollama, openai, copilot
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.1:8b

# (Frontend Mappings - Mandatory for Next.js browser context)
NEXT_PUBLIC_DEFAULT_PROVIDER=ollama
NEXT_PUBLIC_DEFAULT_MODEL=llama3.1:8b

# --- 🔐 API Keys ---

# Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# GitHub Copilot (SDK / CLI)
GITHUB_TOKEN=your_github_token
COPILOT_MODEL=gpt-4o

# --- 🏠 Local Providers ---

# Ollama (Local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60000

# --- 🛠️ Auth Settings ---
AUTH_TRUST_HOST=true
# (Set this to true for local testing & Docker usage)

# --- 🛠️ MCP Server Settings ---
PORT=41234
DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- 🧪 Debugging ---
PROVIDER_DEBUG=false
